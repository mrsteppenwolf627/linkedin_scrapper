# ============================================
# LINKEDIN SCRAPER V1 - Variables de entorno
# Copia este archivo a .env.local y rellena los valores
# NUNCA subas .env.local a git
# ============================================

# --- SUPABASE ---
# Obtener en: supabase.com → proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Solo para operaciones server-side (bypasa RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (Claude API) ---
# Obtener en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- SERPER.DEV (Google Search) ---
# Obtener en: serper.dev → Dashboard → API Key
SERPER_API_KEY=...

# --- SEGURIDAD ---
# Clave para proteger los endpoints de la API
# Genera una aleatoria: openssl rand -hex 32
SEARCH_API_KEY=change_this_to_a_random_secret_key

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
